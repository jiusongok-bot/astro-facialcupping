---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const popularLinks = [
  { label: "What Is Facial Cupping?", href: "/learn/what-is-facial-cupping" },
  { label: "Facial Cupping Benefits", href: "/benefits/facial-cupping-benefits" },
  { label: "How To Do Facial Cupping", href: "/how-to/how-to-do-facial-cupping" },
  { label: "Facial Cupping FAQ", href: "/learn/facial-cupping-faq" },
  { label: "Safety Guidelines", href: "/safety" },
  { label: "Tools & Kits", href: "/tools" },
];
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Explore our facial cupping guides instead." robots="noindex">
  <Nav />
  <main class="flex-1 flex items-center justify-center">
    <div class="max-w-[600px] mx-auto px-5 py-20 text-center">
      <p class="text-[clamp(4rem,15vw,8rem)] font-bold tracking-tighter text-forest/10 leading-none">404</p>
      <h1 class="mt-4 text-2xl md:text-3xl font-bold tracking-tight text-forest">
        Page Not Found
      </h1>
      <p class="mt-4 text-muted leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Explore our most popular guides below.
      </p>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-3 text-left">
        {popularLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 rounded-[var(--radius-card)] border border-border hover:border-forest/30 hover:bg-white transition-colors"
          >
            <span class="text-sm font-medium text-forest">{link.label}</span>
          </a>
        ))}
      </div>

      <div class="mt-10">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-forest text-bone text-sm font-semibold rounded-[var(--radius-btn)] hover:bg-forest-light transition-colors active:-translate-y-[1px]"
        >
          &larr; Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
