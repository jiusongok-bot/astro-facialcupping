---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PageHero from "@/components/PageHero.astro";
import { getCollection } from "astro:content";
import { filterVisible } from "@/lib/visibility";

// Section → background image mapping
const sectionBgImage: Record<string, string> = {
  learn: "/images/learn.png",
  benefits: "/images/benefits.png",
  "how-to": "/images/howto.png",
  safety: "/images/safety.png",
  tools: "/images/tools.png",
  research: "/images/research.png",
  oils: "/images/oils.png",
  glowcup: "/images/glowcup.png",
  about: "/images/about.png",
};

export async function getStaticPaths() {
  const allSections = await getCollection("sections");
  const allArticles = await getCollection("articles");

  const visibleArticles = filterVisible(allArticles);

  return filterVisible(allSections)
    .sort((a, b) => a.data.order - b.data.order)
    .map((section) => {
      const sectionArticles = visibleArticles.filter(
        (a) => a.data.section === section.id
      );
      return {
        params: { section: section.id },
        props: { section, sectionArticles },
      };
    })
    // Skip sections with no visible articles
    .filter((route) => route.props.sectionArticles.length > 0);
}

const { section, sectionArticles } = Astro.props;
const bgImage = sectionBgImage[section.id] ?? "/images/hero-bg.png";
---

<BaseLayout title={section.data.title} description={section.data.description}>
  <Nav />
  <main class="flex-1">
    <!-- Section Hero -->
    <PageHero
      title={section.data.title}
      description={section.data.description}
      backgroundImage={bgImage}
    />

    <div class="max-w-[1200px] mx-auto px-5 pt-6 pb-20">
      <Breadcrumb items={[{ label: section.data.title, href: `/${section.id}` }]} />

      <!-- Articles grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">
        {sectionArticles.map((article) => {
          const slug = article.id.split("/")[1];
          return (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/${section.id}/${slug}`}
              tag={section.data.title}
            />
          );
        })}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
