---
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";
import { filterVisible } from "@/lib/visibility";

export async function getStaticPaths() {
  const allArticles = await getCollection("articles");
  const allSections = await getCollection("sections");

  const visibleArticles = filterVisible(allArticles);
  const paths = [];

  for (const entry of visibleArticles) {
    // entry.id is like "learn/what-is" (without .md)
    const [sectionSlug, articleSlug] = entry.id.split("/");
    if (!articleSlug) continue;

    const sectionEntry = allSections.find((s) => s.id === sectionSlug);
    const sectionTitle = sectionEntry?.data.title ?? sectionSlug;

    // Find related articles (same section, excluding current, only visible)
    const related = visibleArticles
      .filter((a) => a.data.section === sectionSlug && a.id !== entry.id)
      .slice(0, 3);

    paths.push({
      params: { section: sectionSlug, slug: articleSlug },
      props: { entry, sectionTitle, sectionSlug, related },
    });
  }

  return paths;
}

const { entry, sectionTitle, sectionSlug, related } = Astro.props;
const { Content } = await render(entry);

// OG image mapping
const sectionOG: Record<string, string> = {
  learn: "/images/learn.webp",
  benefits: "/images/benefits.webp",
  "how-to": "/images/howto.webp",
  safety: "/images/safety.webp",
  tools: "/images/research.webp",
  research: "/images/research.webp",
  oils: "/images/articles/jade-roller-skincare.jpg",
  comparisons: "/images/articles/silicone-therapy.jpg",
  brands: "/images/articles/skincare-cream.jpg",
  glowcup: "/images/articles/woman-cupping-cup.jpg",
  about: "/images/articles/doctor-smiling.jpg",
};
const ogImage = sectionOG[sectionSlug] ?? "/images/hero.webp";

const articleSlug = entry.id.split("/")[1];
const siteURL = Astro.site?.toString().replace(/\/$/, "") ?? "";
const articleURL = `${siteURL}/${sectionSlug}/${articleSlug}`;
const isFAQ = articleSlug.toLowerCase().includes("faq");
const isContact = articleSlug === "contact";
const isHowTo = sectionSlug === "how-to";

// Build author object — use Organization for team name, Person for real names
const authorType = entry.data.author === "FacialCupping.com Team" ? "Organization" : "Person";
const authorSchema = {
  "@type": authorType,
  name: entry.data.author,
};

// Build schema: FAQPage > HowTo > ContactPage > Article
function buildSchema() {
  if (isFAQ) {
    return {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        { "@type": "Question", name: "Is facial cupping painful?", acceptedAnswer: { "@type": "Answer", text: "No. Facial cupping should feel like a gentle pulling sensation, similar to a massage with light suction. If you experience pain, the suction is too strong. Silicone cups allow you to control the suction by squeezing the cup before placing it on the skin." } },
        { "@type": "Question", name: "Does facial cupping leave marks?", acceptedAnswer: { "@type": "Answer", text: "Unlike body cupping, proper facial cupping should not leave marks. The cups are kept in constant motion with light suction. If you notice redness, it should fade within a few minutes." } },
        { "@type": "Question", name: "How often should I do facial cupping?", acceptedAnswer: { "@type": "Answer", text: "Most practitioners recommend starting with 2–3 sessions per week, each lasting 5–10 minutes. As your skin becomes accustomed, some users increase to daily sessions." } },
        { "@type": "Question", name: "Can I do facial cupping at home?", acceptedAnswer: { "@type": "Answer", text: "Yes. Many facial cupping sets are designed for home use. Always use a high-quality facial oil for glide, work on clean skin, and follow a routine that moves outward and upward." } },
        { "@type": "Question", name: "Do I need special products for facial cupping?", acceptedAnswer: { "@type": "Answer", text: "Using a facial oil or serum is strongly recommended. Look for jojoba oil, rosehip oil, or hyaluronic acid that provide smooth glide without clogging pores." } },
        { "@type": "Question", name: "Can I do facial cupping if I have acne or rosacea?", acceptedAnswer: { "@type": "Answer", text: "Proceed with caution. Avoid cupping over active breakouts or severely inflamed rosacea. Once healed, gentle facial cupping may support recovery by promoting circulation and lymphatic drainage." } },
        { "@type": "Question", name: "How long does it take to see results?", acceptedAnswer: { "@type": "Answer", text: "Some people notice an immediate glow after a single session. For longer-term benefits like improved skin tone and a more sculpted appearance, most users report visible changes within 2–4 weeks of consistent practice." } },
        { "@type": "Question", name: "Can facial cupping be combined with other treatments?", acceptedAnswer: { "@type": "Answer", text: "Yes, it pairs well with serums, gua sha, and LED light therapy. However, avoid combining with strong chemical peels, microneedling, or retinoid treatments on the same day." } },
        { "@type": "Question", name: "Is facial cupping safe during pregnancy?", acceptedAnswer: { "@type": "Answer", text: "Facial cupping is generally considered safe during pregnancy because it is non-invasive and uses very light suction. Always check with your OB-GYN before starting any new skincare practice." } },
        { "@type": "Question", name: "What size cup should I use for different areas?", acceptedAnswer: { "@type": "Answer", text: "Use large cups (2 inches) on cheeks, jawline, and forehead. Medium cups (1.5 inches) for neck. Small cups (1 inch) for under-eye area, nasolabial folds, and around the nose." } },
        { "@type": "Question", name: "How do I clean and maintain my cups?", acceptedAnswer: { "@type": "Answer", text: "Wash cups with warm water and mild soap after each use. Dry completely before storing. Do a weekly deep clean with a warm water and white vinegar solution." } },
        { "@type": "Question", name: "What ingredients should I look for in a cupping oil?", acceptedAnswer: { "@type": "Answer", text: "Look for jojoba oil, rosehip oil, hyaluronic acid serums, squalane, and vitamin E. Avoid mineral oil-based products and heavy petroleum jelly." } },
        { "@type": "Question", name: "Can facial cupping reduce fine lines and wrinkles?", acceptedAnswer: { "@type": "Answer", text: "Facial cupping may help soften fine lines over time by stimulating blood circulation and promoting collagen production. Combine with sunscreen, retinoids, and hydration for best results." } },
        { "@type": "Question", name: "Silicone vs glass cups — which is better?", acceptedAnswer: { "@type": "Answer", text: "Silicone cups are generally recommended for beginners and home use. They offer easy suction control, are durable, hygienic, flexible on facial contours, and more affordable than glass cups." } },
        { "@type": "Question", name: "Can facial cupping help with puffiness?", acceptedAnswer: { "@type": "Answer", text: "Yes. The gentle suction stimulates lymphatic drainage, helping move excess fluid away from the face. This is particularly effective for morning puffiness around the eyes and cheeks." } }
      ]
    };
  }
  if (isContact) {
    return {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      name: entry.data.title,
      description: entry.data.description,
      url: articleURL,
      mainEntity: {
        "@type": "Organization",
        name: "FacialCupping.com",
        url: siteURL,
        contactPoint: {
          "@type": "ContactPoint",
          contactType: "customer service",
          email: "contact@facialcupping.com",
          availableLanguage: "English"
        }
      }
    };
  }
  if (isHowTo) {
    return {
      "@context": "https://schema.org",
      "@type": "HowTo",
      name: entry.data.title,
      description: entry.data.description,
      url: articleURL,
      image: ogImage ? `${siteURL}${ogImage}` : undefined,
      author: authorSchema,
      publisher: {
        "@type": "Organization",
        name: "FacialCupping.com",
      },
      totalTime: "PT10M",
      tool: [
        { "@type": "HowToTool", name: "Facial cupping set (silicone, 3–4 sizes)" },
      ],
      supply: [
        { "@type": "HowToSupply", name: "Facial oil or serum (jojoba, grapeseed, or squalane)" },
      ],
    };
  }
  return {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description: entry.data.description,
    url: articleURL,
    image: ogImage ? `${siteURL}${ogImage}` : undefined,
    author: authorSchema,
    publisher: {
      "@type": "Organization",
      name: "FacialCupping.com",
    },
    datePublished: entry.data.datePublished,
    dateModified: entry.data.dateUpdated || entry.data.datePublished,
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": articleURL,
    },
    isPartOf: {
      "@type": "WebPage",
      "@id": `${siteURL}/${sectionSlug}`,
    },
  };
}
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogType="article"
  author={entry.data.author}
  datePublished={entry.data.datePublished}
  dateUpdated={entry.data.dateUpdated}
  breadcrumbs={[
    { label: sectionTitle, href: `/${sectionSlug}` },
    { label: entry.data.title, href: `/${sectionSlug}/${entry.id.split("/")[1]}` },
  ]}
>
  <div class="prose-content">
    <Content />
  </div>

  <!-- Article / FAQPage JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(buildSchema())} />

  <!-- Related articles -->
  {related.length > 0 && (
    <div class="mt-16 pt-10 border-t border-border">
      <h2 class="text-xl font-semibold text-forest mb-6">Related in {sectionTitle}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {related.map((r: { id: string; data: { title: string; description: string } }) => (
          <a
            href={`/${r.data.section}/${r.id.split("/")[1]}`}
            class="block p-4 rounded-[var(--radius-card)] border border-border hover:border-forest/30 transition-colors"
          >
            <h3 class="text-sm font-semibold text-forest mb-1">{r.data.title}</h3>
            <p class="text-xs text-muted line-clamp-2">{r.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}
</ArticleLayout>
