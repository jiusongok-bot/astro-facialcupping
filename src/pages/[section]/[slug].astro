---
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const allArticles = await getCollection("articles");
  const allSections = await getCollection("sections");

  const paths = [];

  for (const entry of allArticles) {
    // entry.id is like "learn/what-is" (without .md)
    const [sectionSlug, articleSlug] = entry.id.split("/");
    if (!articleSlug) continue;

    const sectionEntry = allSections.find((s) => s.id === sectionSlug);
    const sectionTitle = sectionEntry?.data.title ?? sectionSlug;

    // Find related articles (same section, excluding current)
    const related = allArticles
      .filter((a) => a.data.section === sectionSlug && a.id !== entry.id)
      .slice(0, 3);

    paths.push({
      params: { section: sectionSlug, slug: articleSlug },
      props: { entry, sectionTitle, sectionSlug, related },
    });
  }

  return paths;
}

const { entry, sectionTitle, sectionSlug, related } = Astro.props;
const { Content } = await render(entry);

// OG image mapping
const sectionOG: Record<string, string> = {
  learn: "/images/learn.png",
  benefits: "/images/benefits.png",
  "how-to": "/images/howto.png",
  safety: "/images/safety.png",
  tools: "/images/research.png",
  research: "/images/research.png",
  comparisons: "/images/articles/silicone-therapy.jpg",
  brands: "/images/articles/skincare-cream.jpg",
  glowcup: "/images/articles/woman-cupping-cup.jpg",
  about: "/images/articles/doctor-smiling.jpg",
};
const ogImage = sectionOG[sectionSlug] ?? "/images/hero.png";

const articleSlug = entry.id.split("/")[1];
const articleURL = `https://facialcupping.com/${sectionSlug}/${articleSlug}`;
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  breadcrumbs={[
    { label: sectionTitle, href: `/${sectionSlug}` },
    { label: entry.data.title, href: `/${sectionSlug}/${entry.id.split("/")[1]}` },
  ]}
>
  <div class="prose-content">
    <Content />
  </div>

  <!-- Article JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description: entry.data.description,
    url: articleURL,
    image: ogImage ? `https://facialcupping.com${ogImage}` : undefined,
    isPartOf: {
      "@type": "WebPage",
      url: articleURL,
    },
  })} />

  <!-- Related articles -->
  {related.length > 0 && (
    <div class="mt-16 pt-10 border-t border-border">
      <h2 class="text-xl font-semibold text-forest mb-6">Related in {sectionTitle}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {related.map((r: { id: string; data: { title: string; description: string } }) => (
          <a
            href={`/${r.data.section}/${r.id.split("/")[1]}`}
            class="block p-4 rounded-[var(--radius-card)] border border-border hover:border-forest/30 transition-colors"
          >
            <h3 class="text-sm font-semibold text-forest mb-1">{r.data.title}</h3>
            <p class="text-xs text-muted line-clamp-2">{r.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}
</ArticleLayout>
