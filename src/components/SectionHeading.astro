---
interface Props {
  title: string;
  subtitle?: string;
  href?: string;
  hrefLabel?: string;
}

const { title, subtitle, href, hrefLabel = "View all" } = Astro.props;
---

<div class="flex items-end justify-between mb-8">
  <div>
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-forest">
      {title}
    </h2>
    {subtitle && (
      <p class="mt-2 text-muted max-w-[55ch]">{subtitle}</p>
    )}
  </div>
  {href && (
    <a
      href={href}
      class="hidden sm:inline-block text-sm font-medium text-amber hover:text-forest transition-colors shrink-0 ml-4"
    >
      {hrefLabel} &rarr;
    </a>
  )}
</div>
