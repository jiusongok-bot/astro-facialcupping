---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: NavItem[];
  currentPath: string;
}

const { navItems, currentPath } = Astro.props;
---

<div class="lg:hidden" id="mobile-menu">
  <button
    id="mobile-menu-btn"
    class="p-2 text-forest hover:bg-sage rounded-[var(--radius-btn)] transition-colors"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <!-- Hamburger icon -->
    <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"/></svg>
    <!-- Close icon (hidden by default) -->
    <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/></svg>
  </button>

  <div id="mobile-menu-panel" class="hidden absolute top-[68px] left-0 right-0 bg-bone border-b border-border shadow-lg">
    <ul class="max-w-[1200px] mx-auto px-5 py-4 space-y-1">
      {navItems.map((item) => {
        const isActive =
          currentPath === item.href ||
          (item.href !== "/" && currentPath.startsWith(item.href));
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                "block px-4 py-3 text-sm font-medium rounded-[var(--radius-btn)] transition-colors",
                isActive ? "text-forest bg-sage" : "text-muted hover:text-forest hover:bg-sage/60",
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const panel = document.getElementById('mobile-menu-panel');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !panel.classList.contains('hidden');
    panel.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a link is clicked
  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      panel.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
