---
import { Picture } from "astro:assets";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  alt: string;
  priority?: boolean;
}

const { title, description, image, alt, priority = false } = Astro.props;
---

<!-- Hero banner with responsive image -->
<div class="relative overflow-hidden min-h-[400px] lg:aspect-[330/100]">
  <Picture
    src={image}
    alt={alt}
    formats={["webp"]}
    widths={[640, 1024, 1536]}
    sizes="(max-width: 768px) 100vw, 1200px"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading={priority ? "eager" : "lazy"}
    fetchpriority={priority ? "high" : undefined}
  />
</div>

<!-- Title & description below banner -->
<div class="max-w-[1200px] mx-auto px-5 pt-8 pb-2">
  <h1 class="text-[clamp(1.75rem,5vw,3.25rem)] font-bold tracking-tighter text-forest leading-[1.08]">
    {title}
  </h1>
  <p class="mt-3 text-[clamp(0.875rem,2.5vw,1.05rem)] text-muted max-w-[65ch] leading-relaxed">
    {description}
  </p>
</div>
