---
interface Props {
  title: string;
  description: string;
  backgroundImage: string;
}

const { title, description, backgroundImage } = Astro.props;
const heroStyle = `background-image: url(${backgroundImage}); background-size: cover; background-position: center top;`;
---

<!-- Image banner -->
<div
  class="relative overflow-hidden min-h-[400px] lg:aspect-[330/100]"
  style={heroStyle}
>
</div>

<!-- Title & description below banner -->
<div class="max-w-[1200px] mx-auto px-5 pt-8 pb-2">
  <h1 class="text-[clamp(1.75rem,5vw,3.25rem)] font-bold tracking-tighter text-forest leading-[1.08]">
    {title}
  </h1>
  <p class="mt-3 text-[clamp(0.875rem,2.5vw,1.05rem)] text-muted max-w-[65ch] leading-relaxed">
    {description}
  </p>
</div>
