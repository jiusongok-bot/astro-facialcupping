---
interface Props {
  title: string;
  description: string;
  href: string;
  tag?: string;
}

const { title, description, href, tag } = Astro.props;
---

<a
  href={href}
  class="group block rounded-[var(--radius-card)] overflow-hidden bg-white border border-border hover:border-forest/30 hover:shadow-md transition-all active:-translate-y-[1px]"
>
  <div class="p-5">
    {tag && (
      <span class="text-xs font-medium text-amber uppercase tracking-wider">
        {tag}
      </span>
    )}
    <h3 class="text-base font-semibold text-forest mt-1.5 mb-2 group-hover:text-forest-light transition-colors leading-snug">
      {title}
    </h3>
    <p class="text-sm text-muted leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>
</a>
