---
import { getCollection } from "astro:content";
import { filterVisible } from "@/lib/visibility";

const year = new Date().getFullYear();

const allArticles = await getCollection("articles");
const allSections = await getCollection("sections");
const visibleArticleIds = new Set(filterVisible(allArticles).map((a) => a.id));
const visibleSectionIds = new Set(filterVisible(allSections).map((s) => s.id));

/** A footer link is visible if its target (section or article) is visible. */
function isLinkVisible(href: string): boolean {
  const id = href.slice(1); // strip leading /
  return visibleSectionIds.has(id) || visibleArticleIds.has(id);
}

const allColumns = [
  {
    title: "Learn",
    links: [
      { label: "What Is Facial Cupping", href: "/learn/what-is-facial-cupping" },
      { label: "Benefits", href: "/benefits" },
      { label: "How To", href: "/how-to" },
      { label: "Safety", href: "/safety" },
    ],
  },
  {
    title: "Explore",
    links: [
      { label: "Tools & Sets", href: "/tools" },
      { label: "Oils", href: "/oils" },
      { label: "Research", href: "/research" },
    ],
  },
  {
    title: "Compare",
    links: [
      { label: "Facial Cupping vs Gua Sha", href: "/comparisons/vs-gua-sha" },
      { label: "Facial Cupping vs Jade Roller", href: "/comparisons/vs-jade-roller" },
      { label: "Silicone vs Glass Cups", href: "/tools/silicone" },
      { label: "Brand Reviews", href: "/brands" },
    ],
  },
  {
    title: "GlowCup",
    links: [
      { label: "Our Story", href: "/glowcup/story" },
      { label: "Philosophy", href: "/glowcup/philosophy" },
      { label: "Product Standards", href: "/glowcup/standards" },
      { label: "Contact", href: "/glowcup/contact" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/about" },
      { label: "Editorial Guidelines", href: "/about/editorial" },
      { label: "Mission", href: "/about/mission" },
      { label: "Contact", href: "/about/contact" },
    ],
  },
];

// Filter out invisible links, then drop columns with no remaining links
const columns = allColumns
  .map((col) => ({ ...col, links: col.links.filter((l) => isLinkVisible(l.href)) }))
  .filter((col) => col.links.length > 0);
---

<footer class="bg-forest text-bone/80">
  <div class="max-w-[1200px] mx-auto px-5 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      <!-- Brand col -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-block">
          <img src="/FacialCupping-logo.png" alt="FacialCupping.com" class="h-[48px] w-auto brightness-0 invert opacity-90 hover:opacity-100 transition-opacity" width="400" height="97" />
        </a>
        <p class="mt-3 text-sm leading-relaxed text-bone/60 max-w-[28ch]">
          The Facial Cupping Resource Center.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-bone mb-4">{col.title}</h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/50 hover:text-bone transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 pt-6 border-t border-bone/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-bone/40">
        &copy; {year} FacialCupping.com. All rights reserved.
      </p>
      {visibleSectionIds.has('glowcup') && (
        <p class="text-xs text-bone/40">
          Powered by <a href="/glowcup" class="text-amber/70 hover:text-amber transition-colors">GlowCup</a>
        </p>
      )}
    </div>
  </div>
</footer>
