---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Learn",
    links: [
      { label: "What Is Facial Cupping", href: "/learn/what-is" },
      { label: "Therapy", href: "/learn/therapy" },
      { label: "History", href: "/learn/history" },
      { label: "How It Works", href: "/learn/how-it-works" },
    ],
  },
  {
    title: "Explore",
    links: [
      { label: "How To", href: "/how-to" },
      { label: "Safety", href: "/safety" },
      { label: "Tools", href: "/tools" },
      { label: "Comparisons", href: "/comparisons" },
    ],
  },
  {
    title: "Research",
    links: [
      { label: "Before & After", href: "/research/before-after" },
      { label: "Evidence Review", href: "/research/evidence" },
      { label: "Results Timeline", href: "/research/results-timeline" },
      { label: "Expert Opinions", href: "/research/experts" },
    ],
  },
  {
    title: "Brands",
    links: [
      { label: "Primally Pure", href: "/brands/primally-pure" },
      { label: "Bellabaci", href: "/brands/bellabaci" },
      { label: "Rena Chris", href: "/brands/rena-chris" },
      { label: "Amazon Sets", href: "/brands/amazon" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "GlowCup", href: "/glowcup" },
      { label: "Mission", href: "/about/mission" },
      { label: "Editorial", href: "/about/editorial" },
      { label: "Contact", href: "/about/contact" },
    ],
  },
];
---

<footer class="bg-forest text-bone/80">
  <div class="max-w-[1200px] mx-auto px-5 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      <!-- Brand col -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-lg font-bold text-bone tracking-tight">
          FacialCupping<span class="text-amber">.com</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-bone/60 max-w-[28ch]">
          The Facial Cupping Resource Center.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-bone mb-4">{col.title}</h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/50 hover:text-bone transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 pt-6 border-t border-bone/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-bone/40">
        &copy; {year} FacialCupping.com. All rights reserved.
      </p>
      <p class="text-xs text-bone/40">
        Powered by <a href="/glowcup" class="text-amber/70 hover:text-amber transition-colors">GlowCup</a>
      </p>
    </div>
  </div>
</footer>
