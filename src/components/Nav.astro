---
import MobileMenu from "./MobileMenu";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Learn", href: "/learn" },
  { label: "Benefits", href: "/benefits" },
  { label: "How To", href: "/how-to" },
  { label: "Safety", href: "/safety" },
  { label: "Tools", href: "/tools" },
  { label: "Research", href: "/research" },
  { label: "Comparisons", href: "/comparisons" },
  { label: "Brands", href: "/brands" },
  { label: "GlowCup", href: "/glowcup" },
  { label: "About", href: "/about" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bone/90 backdrop-blur-md border-b border-border">
  <nav class="max-w-[1200px] mx-auto px-5 h-[68px] flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-forest shrink-0">
      FacialCupping<span class="text-amber">.com</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-0.5">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "px-2 py-2 text-sm font-medium rounded-[var(--radius-btn)] transition-colors",
              currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                ? "text-forest bg-sage"
                : "text-muted hover:text-forest hover:bg-sage/60",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile trigger -->
    <MobileMenu client:load navItems={navItems} currentPath={currentPath} />
  </nav>
</header>
