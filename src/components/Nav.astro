---
import MobileMenu from "./MobileMenu.astro";
import { getCollection } from "astro:content";
import { filterVisible } from "@/lib/visibility";

const allSections = await getCollection("sections");
const allArticles = await getCollection("articles");

const visibleSections = filterVisible(allSections)
  .sort((a, b) => a.data.order - b.data.order)
  .filter((section) => {
    // Only show sections that have at least one visible article
    return filterVisible(allArticles).some((a) => a.data.section === section.id);
  });

const navItems = [
  { label: "Home", href: "/" },
  ...visibleSections.map((s) => ({ label: s.data.title, href: `/${s.id}` })),
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bone/90 backdrop-blur-md border-b border-border">
  <nav class="max-w-[1200px] mx-auto px-5 h-[68px] flex items-center gap-6">
    <!-- Logo on the left -->
    <a href="/" class="shrink-0">
      <img src="/FacialCupping-logo.png" alt="FacialCupping.com" class="h-[48px] w-auto" width="400" height="97" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "px-3 py-2 text-sm font-medium rounded-[var(--radius-btn)] transition-colors",
              currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                ? "text-forest bg-sage"
                : "text-muted hover:text-forest hover:bg-sage/60",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile trigger -->
    <MobileMenu navItems={navItems} currentPath={currentPath} />
  </nav>
</header>
