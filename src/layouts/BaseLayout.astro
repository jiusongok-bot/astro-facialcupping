---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  author?: string;
  datePublished?: string;
  dateUpdated?: string;
}

const {
  title,
  description = "The Facial Cupping Resource Center — learn benefits, techniques, safety and tools.",
  ogImage,
  ogType = "website",
  robots = "index, follow",
  author,
  datePublished,
  dateUpdated,
} = Astro.props;

import "@/styles/global.css";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const siteURL = Astro.site?.toString().replace(/\/$/, "") ?? "";
const isArticle = ogType === "article";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | FacialCupping.com</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="FacialCupping.com" />
    {absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}

    <!-- Article-specific OG meta -->
    {isArticle && datePublished && (
      <meta property="article:published_time" content={new Date(datePublished).toISOString()} />
    )}
    {isArticle && dateUpdated && (
      <meta property="article:modified_time" content={new Date(dateUpdated).toISOString()} />
    )}
    {isArticle && author && (
      <meta property="article:author" content={author} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}

    <!-- WebSite JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "FacialCupping.com",
      url: siteURL,
      description: "The Facial Cupping Resource Center",
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteURL}/?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    })} />

    <!-- Organization JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "FacialCupping.com",
      url: siteURL,
      logo: `${siteURL}/favicon.svg`,
      description: "The Facial Cupping Resource Center — expert guides on techniques, benefits, safety and tools for facial cupping therapy.",
    })} />

    <!-- Google tag (gtag.js) – deferred to avoid render-blocking -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-67J6Q7KSLQ');
      // Defer loading external gtag script until idle
      window.addEventListener('DOMContentLoaded', () => {
        const s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-67J6Q7KSLQ';
        s.async = true;
        document.head.appendChild(s);
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
