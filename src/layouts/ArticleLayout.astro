---
import BaseLayout from "./BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  breadcrumbs: { label: string; href: string }[];
}

const { title, description, ogImage, breadcrumbs } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Nav />
  <main class="flex-1">
    <div class="max-w-[1200px] mx-auto px-5 pt-8 pb-16">
      <Breadcrumb items={breadcrumbs} />
      <article class="mt-8 max-w-[72ch]">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-forest leading-tight">
          {title}
        </h1>
        <div class="mt-8 prose-content">
          <slot />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>
