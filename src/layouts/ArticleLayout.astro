---
import BaseLayout from "./BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  breadcrumbs: { label: string; href: string }[];
  author?: string;
  datePublished?: string;
  dateUpdated?: string;
}

const { title, description, ogImage, ogType, breadcrumbs, author, datePublished, dateUpdated } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType={ogType}
  author={author}
  datePublished={datePublished}
  dateUpdated={dateUpdated}
>
  <Nav />
  <main class="flex-1">
    <div class="max-w-[1200px] mx-auto px-5 pt-8 pb-16">
      <Breadcrumb items={breadcrumbs} />
      <article class="mt-8 max-w-[72ch]">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-forest leading-tight">
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 mt-4 text-sm text-muted">
          {author && <span class="font-medium text-forest">{author}</span>}
          {datePublished && (
            <time datetime={datePublished} class="text-muted">
              {new Date(datePublished).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </time>
          )}
          {dateUpdated && dateUpdated !== datePublished && (
            <span class="text-muted/60">
              (Updated {new Date(dateUpdated).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })})
            </span>
          )}
        </div>
        <div class="mt-8 prose-content">
          <slot />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>
